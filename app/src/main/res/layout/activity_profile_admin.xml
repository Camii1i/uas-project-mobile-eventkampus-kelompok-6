<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="?attr/colorTextPrimary"
            app:title="Profil Admin"
            app:titleTextColor="?attr/colorTextPrimary" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="@drawable/gradient_indigo">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAvatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_centerInParent="true"
                    app:cardBackgroundColor="@color/indigo_primary"
                    app:cardCornerRadius="50dp"
                    app:strokeColor="@color/light_card"
                    app:strokeWidth="4dp">

                    <TextView
                        android:id="@+id/tvAdminInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="A"
                        android:textColor="@color/light_card"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvAdminBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/cardAvatar"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="-12dp"
                    android:background="@drawable/bg_badge_indigo"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:text="ADMIN"
                    android:textColor="@color/light_card"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:elevation="6dp"/>

                <TextView
                    android:id="@+id/tvAdminProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvAdminBadge"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="12dp"
                    android:text="Nama Admin"
                    android:textColor="@color/light_card"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAdminProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvAdminProfileName"
                    android:layout_centerHorizontal="true"
                    android:text="admin@universe.com"
                    android:textColor="@color/indigo_muted"
                    android:textSize="14sp" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-24dp"
                android:background="@drawable/bg_card"
                android:backgroundTint="?attr/colorBackground"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Statistik Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/indigo_primary"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_success_circle"
                            android:backgroundTint="@color/indigo_light"
                            android:padding="8dp"
                            android:src="@drawable/ic_universe"
                            app:tint="@color/light_card" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTotalEvent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/light_card"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Event Dibuat"
                                android:textColor="@color/indigo_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Info Card Role -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Informasi Jabatan"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="?attr/colorCard"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="?attr/colorBorder"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="@color/indigo_primary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Role Pengguna"
                                android:textColor="?attr/colorTextSecondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvAdminRole"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Super Admin"
                                android:textColor="?attr/colorTextPrimary"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Actions -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditAdminProfile"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:text="Edit Profil Admin"
                    android:textAllCaps="false"
                    android:textColor="@color/light_card"
                    app:backgroundTint="@color/indigo_primary"
                    app:cornerRadius="14dp"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminLogout"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Keluar Dashboard"
                    android:textAllCaps="false"
                    android:textColor="@color/danger"
                    app:cornerRadius="14dp"
                    app:icon="@android:drawable/ic_lock_power_off"
                    app:iconGravity="textStart"
                    app:iconTint="@color/danger"
                    app:strokeColor="@color/danger" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>