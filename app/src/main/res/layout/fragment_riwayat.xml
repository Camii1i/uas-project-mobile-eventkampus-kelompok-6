<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Riwayat Pendaftaran"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorTextPrimary" />

        <LinearLayout
            android:id="@+id/toggleViewModeRiwayat"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_toggle_container"
            android:padding="3dp">

            <LinearLayout
                android:id="@+id/btnListModeRiwayat"
                android:layout_width="34dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/ivListModeRiwayat"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_list"
                    app:tint="?attr/colorTextPrimary" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnGridModeRiwayat"
                android:layout_width="34dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/ivGridModeRiwayat"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_grid"
                    app:tint="?attr/colorTextPrimary" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnCardModeRiwayat"
                android:layout_width="34dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/ivCardModeRiwayat"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_card"
                    app:tint="?attr/colorTextPrimary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRiwayat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>