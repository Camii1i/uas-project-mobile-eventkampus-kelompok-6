<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardEvent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorBorder"
    app:cardBackgroundColor="?attr/colorCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/badgeKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_badge_kategori"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_tag"
                    app:tint="@color/indigo_primary" />

                <TextView
                    android:id="@+id/tvKategori"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/indigo_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:text="Kategori" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tvNama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="?attr/colorTextPrimary"
            android:textStyle="bold"
            android:textSize="17sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Nama Event" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_calendar"
                app:tint="?attr/colorTextMuted" />

            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Tanggal" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_location"
                app:tint="?attr/colorTextMuted" />

            <TextView
                android:id="@+id/tvLokasi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Lokasi" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetail"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:text="Lihat Detail"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/indigo_primary"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="textEnd"
            app:iconTint="@android:color/white"
            app:iconSize="16dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>